<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ComboBox?>
<BorderPane style="-fx-background-color: #000000"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.transmitter.MainController">
 
    <!-- Port selection -->
    <top>
        <HBox spacing = "8">
            <Label text="PORT"/>
            <ComboBox fx:id="portComboBox"/>
            <Button text="Connect"/>
        </HBox>
    </top>

    <!-- Message feed -->
    <center>
        <TextArea fx:id="messageArea" editable="false"/>
    </center>

    <!-- Input bar at the bottom -->
    <bottom>
        <HBox spacing="8">
            <TextField fx:id="messageInput" promptText="Type a message..." HBox.hgrow="ALWAYS"/>
            <Button text="SEND" onAction="#onSend"/>
        </HBox>
    </bottom>

</BorderPane>